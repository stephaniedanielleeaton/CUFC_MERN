{
  "name": "cufc-mern",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "packages/*",
    "e2e"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=@cufc/shared && npm run build --workspace=client && npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "heroku-postbuild": "npm run build",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspace=client",
    "test:e2e": "npm run test --workspace=e2e",
    "test:e2e:full": "node test-all.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "24.x"
  }
}
